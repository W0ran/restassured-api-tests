<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="RestfulApiDev Test Suite" verbose="1" parallel="none" thread-count="1">

    <test name="GET Tests">
        <classes>
            <class name="com.restfulapidev.tests.GetObjectsTests"/>
        </classes>
    </test>

    <test name="POST Tests">
        <classes>
            <class name="com.restfulapidev.tests.CreateObjectTests"/>
        </classes>
    </test>

    <test name="PUT/PATCH Tests">
        <classes>
            <class name="com.restfulapidev.tests.UpdateObjectTests"/>
        </classes>
    </test>

    <test name="DELETE Tests">
        <classes>
            <class name="com.restfulapidev.tests.DeleteObjectTests"/>
        </classes>
    </test>

</suite>