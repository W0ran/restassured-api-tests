{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Single Object Response Schema",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "data": {
      "type": ["object", "null"]
    },
    "createdAt": {
      "type": "integer"
    },
    "updatedAt": {
      "type": "integer"
    }
  },
  "required": ["id", "name"],
  "additionalProperties": false
}