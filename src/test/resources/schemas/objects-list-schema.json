{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Objects List Response Schema",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "id": {
        "type": "string"
      },
      "name": {
        "type": "string"
      },
      "data": {
        "type": ["object", "null"]
      }
    },
    "required": ["id", "name"],
    "additionalProperties": false
  }
}